{
  "audio": {
    "sample_rate": 16000,
    "channels": 1,
    "frame_ms": 50,
    "calibration_seconds": 5
  },
  "thresholds": {
    "speaking_delta_db": 6,
    "loud_delta_db": 20,
    "quiet_delta_db": 10,
    "default_ambient_dbfs": -50,
    "min_safe_dbfs": -60,
    "max_safe_dbfs": -10
  },
  "buzz": {
    "cooldown_ms": 1500,
    "hold_ms": 400,
    "loud_vibration_ms": 120,
    "quiet_vibration_ms": 600,
    "loud_colour": "#ff3b30",
    "quiet_colour": "#0a84ff",
    "safe_colour": "#1c1c1e"
  },
  "speechmatics": {
    "language": "en",
    "operating_point": "enhanced",
    "max_delay": 1.5,
    "enable_partials": true
  },
  "training": {
    "min_duration_seconds": 10,
    "max_duration_seconds": 180,
    "prompts": [
      "Tell me about a project you are proud of and what made it work.",
      "Describe a challenge you faced this week and how you approached it.",
      "Explain something complex from your job to someone who has never done it."
    ]
  },
  "coaching_live": {
    "tick_seconds": 8,
    "max_tip_chars": 70
  },
  "coaching": {
    "model": "gemma4:e4b",
    "live_model": "gemma4:e4b",
    "max_tokens_report": 1200,
    "max_tokens_live": 120
  },
  "video_emotion": {
    "enabled": true,
    "engine": "onnx",
    "model_name": "enet_b0_8_best_vgaf",
    "device": "cpu",
    "fps_sample": 2.0,
    "face_conf_min": 0.35,
    "fusion_window_seconds": 1.0,
    "audio_weight": 0.6,
    "video_weight": 0.4
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  }
}
