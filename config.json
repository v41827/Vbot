{
  "audio": {
    "sample_rate": 16000,
    "channels": 1,
    "frame_ms": 50,
    "calibration_seconds": 5
  },
  "thresholds": {
    "speaking_delta_db": 6,
    "loud_delta_db": 20,
    "quiet_delta_db": 10,
    "default_ambient_dbfs": -50,
    "min_safe_dbfs": -60,
    "max_safe_dbfs": -10
  },
  "buzz": {
    "cooldown_ms": 1500,
    "hold_ms": 400,
    "loud_vibration_ms": 120,
    "quiet_vibration_ms": 600,
    "loud_colour": "#ff3b30",
    "quiet_colour": "#0a84ff",
    "safe_colour": "#1c1c1e"
  },
  "speechmatics": {
    "language": "en",
    "operating_point": "enhanced",
    "max_delay": 0.7,
    "enable_partials": true
  },
  "live_stream": {
    "target_sample_rate": 16000,
    "chunk_samples": 2048,
    "send_interval_ms": 200
  },
  "thymia_sentinel": {
    "enabled": true,
    "user_label": "training-user",
    "policies": ["demo_wellbeing_awareness"]
  },
  "training": {
    "min_duration_seconds": 10,
    "max_duration_seconds": 180,
    "prompts": [
      "Tell me about a project you are proud of and what made it work.",
      "Describe a challenge you faced this week and how you approached it.",
      "Explain something complex from your job to someone who has never done it."
    ]
  },
  "coaching_live": {
    "tick_seconds": 8,
    "max_tip_chars": 70
  },
  "coaching": {
    "model": "gemma4:e4b",
    "live_model": "gemma4:e4b",
    "max_tokens_report": 1200,
    "max_tokens_live": 120
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  }
}
